# Environment Configuration - Copy to .env and update values

# API Configuration
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=AI Surveillance System

# Frontend Configuration
VITE_PORT=3000
VITE_POLLING_INTERVAL=1000

# Backend Configuration (for reference)
# PYTHON_FLASK_PORT=5000
# PYTHON_GRID_ROWS=3
# PYTHON_GRID_COLS=4
# PYTHON_CONFIDENCE=0.45

# Feature Flags
VITE_ENABLE_GRID_OVERLAY=true
VITE_ENABLE_RECORDING=true
VITE_ENABLE_ALERTS=true

# Debug Mode
VITE_DEBUG=false
